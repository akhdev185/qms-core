# Google API Configuration (client-side, exposed to browser)
VITE_GOOGLE_API_KEY=your_google_api_key_here
VITE_SPREADSHEET_ID=your_spreadsheet_id_here

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google OAuth Configuration
# احصل على هذه القيم من Google Cloud Console
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Redirect URI
# في التطوير المحلي (Local Development):
# REDIRECT_URI=http://localhost:3001/api/auth/callback
#
# في الإنتاج (Production / Vercel):
# REDIRECT_URI=https://your-project-name.vercel.app/api/auth/callback

# Refresh Token
# اترك هذا فارغاً في البداية.
# بعد تشغيل المشروع، قم بزيارة /api/auth واتبع التعليمات للحصول على هذا الرمز.
GOOGLE_REFRESH_TOKEN=
